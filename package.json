{
  "name": "katsu-leaflet",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && bun compressor",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "compressor": "node ./scripts/compressor.js",
    "iconhandler": "node ./scripts/iconHandler.js",
    "fix:sharp": "bun add -D sharp --ignore-engines",
    "caprover:archiveInner": "tar czf bundle.tar.gz dist captain-definition Dockerfile nginx.conf",
    "caprover:archive": "bun run caprover:delete && bun run caprover:archiveInner",
    "caprover:build": "bun run build && bun run caprover:archive",
    "caprover:delete": "rm -f bundle.tar.gz"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tsconfig/svelte": "^5.0.2",
    "brotli": "^1.3.3",
    "glob": "^10.3.10",
    "sharp": "^0.33.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-maplibre": "^1.0.0",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "yaml": "^2.4.2"
  }
}
